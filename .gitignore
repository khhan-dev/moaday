**/node_modules/
**/.next/
**/dist/
**/.wrangler/
**/target/
**/data/
# Local environment variables and secrets
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Private keys, certificates and credential exports
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/id_rsa
**/id_rsa.*
**/id_ed25519
**/id_ed25519.*
**/credentials.json
**/credentials-*.json
**/service-account*.json
**/google-services.json
**/GoogleService-Info.plist
**/*.mobileprovision
**/.secrets/
**/secrets/

# Local Spring profiles may contain database or SMTP credentials
**/application-local.yml
**/application-local.yaml
**/application-local.properties
**/application-secret.yml
**/application-secret.yaml
**/application-secret.properties

# Tool-specific authentication files
**/.npmrc
**/.pypirc
**/.netrc
**/.docker/config.json
*.log
/backups/
